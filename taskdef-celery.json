{
  "family": "chatapp-celery",
  "executionRoleArn": "arn:aws:iam::702252494235:role/ecsTaskExecutionRole",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "2048",
  "memory": "8192",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "volumes": [],
  "placementConstraints": [],
  "containerDefinitions": [
    {
      "name": "celery",
      "image": "702252494235.dkr.ecr.ap-south-1.amazonaws.com/chatbot-backend:latest",
      "cpu": 2048,
      "essential": true,
      "command": [
        "celery",
        "-A",
        "app.celery_app",
        "worker",
        "--loglevel=info",
        "--concurrency=2",
        "--pool=prefork",
        "-Q",
        "default"
      ],
      "environment": [],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:702252494235:secret:chatapp-secrets-HyxeOl:DATABASE_URL::"
        },
        {
          "name": "DATABASE_URL1",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:702252494235:secret:chatapp-secrets-HyxeOl:DATABASE_URL1::"
        },
        {
          "name": "OPENAI_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:702252494235:secret:chatapp-secrets-HyxeOl:OPENAI_API_KEY::"
        },
        {
          "name": "OPENAI_API_KEY2",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:702252494235:secret:chatapp-secrets-HyxeOl:OPENAI_API_KEY2::"
        },
        {
          "name": "GOOGLE_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:702252494235:secret:chatapp-secrets-HyxeOl:GOOGLE_API_KEY::"
        },
        {
          "name": "GROQ_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:702252494235:secret:chatapp-secrets-HyxeOl:GROQ_API_KEY::"
        },
        {
          "name": "GROQ",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:702252494235:secret:chatapp-secrets-HyxeOl:GROQ::"
        },
        {
          "name": "TAVILY_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:702252494235:secret:chatapp-secrets-HyxeOl:TAVILY_API_KEY::"
        },
        {
          "name": "LANGSMITH_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:702252494235:secret:chatapp-secrets-HyxeOl:LANGSMITH_API_KEY::"
        },
        {
          "name": "LANGSMITH_TRACING",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:702252494235:secret:chatapp-secrets-HyxeOl:LANGSMITH_TRACING::"
        },
        {
          "name": "LANGSMITH_ENDPOINT",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:702252494235:secret:chatapp-secrets-HyxeOl:LANGSMITH_ENDPOINT::"
        },
        {
          "name": "LANGSMITH_PROJECT",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:702252494235:secret:chatapp-secrets-HyxeOl:LANGSMITH_PROJECT::"
        }
      ],
      "portMappings": [],
      "mountPoints": [],
      "volumesFrom": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/chatapp-celery",
          "awslogs-create-group": "true",
          "awslogs-region": "ap-south-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}